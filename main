    <script>
        // Initialize Lucide icons
        lucide.createIcons();

        // Lead Form Handling
        const leadForm = document.getElementById('lead-form');
        const successMsg = document.getElementById('success-msg');

        leadForm.addEventListener('submit', (e) => {
            e.preventDefault();
            
            // Visual Feedback
            const btn = leadForm.querySelector('button');
            btn.innerHTML = '<span class="flex items-center justify-center gap-2">Processing... <i data-lucide="loader" class="w-4 h-4 animate-spin"></i></span>';
            lucide.createIcons();
            
            setTimeout(() => {
                leadForm.classList.add('hidden');
                successMsg.classList.remove('hidden');
            }, 1500);
        });

        // Mobile Menu Toggle
        const mobileBtn = document.getElementById('mobile-menu-btn');
        mobileBtn.addEventListener('click', () => {
            // Simplified for this demo
            const target = document.querySelector('.hidden.md\\:flex');
            target.classList.toggle('hidden');
            target.classList.toggle('absolute');
            target.classList.toggle('top-16');
            target.classList.toggle('left-0');
            target.classList.toggle('w-full');
            target.classList.toggle('bg-white');
            target.classList.toggle('flex-col');
            target.classList.toggle('p-8');
            target.classList.toggle('shadow-xl');
        });
    </script>
